# ============================================
# HEXAPLAST ERP - ENVIRONMENT CONFIGURATION
# ============================================
# Copy this file to .env and configure for your environment
# For production deployment on Windows 10 on-prem server

# --------------------------------------------
# FRONTEND (Next.js)
# --------------------------------------------
# API Base URL - Backend server endpoint
# Production: Use your server's IP or hostname
# Example: http://192.168.1.100:4001 or http://erp-server.local:4001
NEXT_PUBLIC_API_BASE=http://localhost:4001

# Node Environment
NODE_ENV=production

# --------------------------------------------
# BACKEND (Express)
# --------------------------------------------
# Server Port
PORT=4001

# Production ERP Integration (if applicable)
# Leave empty if not using production module integration
PRODUCTION_ERP_URL=
PRODUCTION_API_SECRET=

# Session Secret (IMPORTANT: Change this in production!)
# Generate a strong random string for production
SESSION_SECRET=change-this-to-a-secure-random-string-in-production

# Database Path (SQLite)
# Default: Uses better-sqlite3 in-memory or file-based
# No configuration needed for SQLite

# --------------------------------------------
# SECURITY NOTES
# --------------------------------------------
# 1. Never commit .env files to Git
# 2. Use strong SESSION_SECRET in production
# 3. Ensure NEXT_PUBLIC_API_BASE points to your backend server
# 4. For LAN deployment, use server's local IP address
# 5. Session-based auth - no JWT tokens used
# 6. Backend is source of truth for all data
