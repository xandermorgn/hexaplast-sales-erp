# ============================================
# HEXAPLAST ERP - ENVIRONMENT CONFIGURATION
# ============================================
# Copy this file to .env and configure for your environment
# Single Next.js process on port 3000

# Node Environment
NODE_ENV=production

# Production ERP Integration (if applicable)
# Leave empty if not using production module integration
PRODUCTION_ERP_URL=
PRODUCTION_API_SECRET=

# --------------------------------------------
# NOTES
# --------------------------------------------
# 1. Never commit .env files to Git
# 2. Session-based auth with HTTP-only cookies
# 3. SQLite database at server/data/sales.db
# 4. Single process: next start -p 3000 -H 0.0.0.0
# 5. No separate backend port needed
